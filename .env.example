# ══════════════════════════════════════════════════════════════
#  TAP — The Aesthetic Peptides
#  Cloud Functions Environment Variables
#
#  HOW TO USE:
#  1. Copy this file:   cp .env.example .env
#  2. Fill in every value below
#  3. Deploy secrets:   firebase functions:secrets:set RESEND_API_KEY
#                       firebase functions:secrets:set ADMIN_EMAIL
#                       firebase functions:secrets:set ADMIN_SECRET
#
#  NEVER commit your actual .env file to version control.
#  NEVER paste real values into this .env.example file.
# ══════════════════════════════════════════════════════════════


# ── RESEND (transactional email) ──────────────────────────────
# Get your API key at: https://resend.com/api-keys
# Ensure your sending domain is verified in Resend before going live.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── ADMIN NOTIFICATION ────────────────────────────────────────
# The email address that receives new order alerts.
# This is the shop owner / fulfillment team inbox.
ADMIN_EMAIL=your-admin-email@example.com


# ── ADMIN SECRET (for setAdminClaim Cloud Function) ───────────
# A long, random string used to authorize calls to setAdminClaim.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Pass as the x-admin-secret header when calling the function.
ADMIN_SECRET=replace-with-a-long-random-string-min-32-chars


# ── FIREBASE PROJECT (reference only — not used by functions) ──
# These are set automatically when you run `firebase use <projectId>`.
# Listed here for documentation purposes only.
#
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com


# ══════════════════════════════════════════════════════════════
#  DEPLOYING SECRETS TO FIREBASE
#
#  Firebase Functions v2 reads secrets via process.env when
#  deployed with Firebase Secret Manager. Set each secret once:
#
#    firebase functions:secrets:set RESEND_API_KEY
#    firebase functions:secrets:set ADMIN_EMAIL
#    firebase functions:secrets:set ADMIN_SECRET
#
#  Then reference them in functions/index.js via process.env.VAR_NAME.
#  Locally, the Firebase Emulator reads from a .env file in /functions.
#
#  For local emulator development, create functions/.env (gitignored)
#  and paste your values there. Do NOT use this root .env.example.
# ══════════════════════════════════════════════════════════════
